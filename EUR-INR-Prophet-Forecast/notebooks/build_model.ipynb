## install and import prophet
!pip install prophet
from prophet import Prophet

## prepare the data for prophet
## prophet requires specific column names "ds" and "y"
prophet_df = euro_to_inr.reset_index()[["date", "eur_inr"]]
prophet_df.columns = ["ds", "y"]
## inspect the prophet dataframe
prophet_df.head()

## initialise the prophet model
model = Prophet(
    daily_seasonality = False,
    weekly_seasonality = False,
    yearly_seasonality = True
)

## train the model
model.fit(prophet_df)

## create future dates (next 30 days)
future = model.make_future_dataframe(periods=30)
## check
future

## generate the forecast
forecast = model.predict(future)
forecast

## plot the forecast
model.plot(forecast)

## plot components that shows trends + seasonality
model.plot_components(forecast)
